#!/bin/sh
commit_msg=$(cat "$1")
pattern="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|infra|revert|merge)(\(.+\))?: .{1,}"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "ERROR: El mensaje de commit no sigue Conventional Commits."
  echo ""
  echo "Formato: <tipo>(<alcance opcional>): <descripción>"
  echo ""
  echo "Tipos permitidos:"
  echo "  feat, fix, docs, style, refactor, perf, test, build, ci, chore, infra, revert, merge"
  echo ""
  echo "Ejemplos:"
  echo "  feat(auth): add JWT login endpoint"
  echo "  fix: resolve null pointer in user service"
  echo "  docs: update README with Docker instructions"
  echo ""
  exit 1
fi
