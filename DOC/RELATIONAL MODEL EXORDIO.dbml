  }
}

Table "project_artifacts" {
  "id" uuid [not null]
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]
  "project_id" uuid [not null]
  "code" "character varying(100)" [not null]
  "name" "character varying(255)" [not null]
  "description" text [not null]
  "block" project_artifact_block_enum [not null]
  "order_index" integer [not null]
  "block_order" integer [not null]
  "status" project_artifact_status_enum [not null, default: `'PENDING'::project_artifact_status_enum`]
  "is_applicable" boolean [not null, default: true]
  "consultant_approved" boolean [not null, default: false]
  "company_approved" boolean [not null, default: false]
  "consultant_approved_at" timestamp
  "company_approved_at" timestamp
  "approved_at" timestamp
  "approved_by_user_id" uuid
  "review_cycles" integer [not null, default: 0]
  "last_rejection_reason" text

  Indexes {
    id [pk, name: "project_artifacts_pkey"]
    (project_id, code) [unique, name: "uq_project_artifact_project_code"]
  }
}

